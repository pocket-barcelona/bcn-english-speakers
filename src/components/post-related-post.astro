---
import type { CollectionEntry } from "astro:content";

type Props = {
	post: CollectionEntry<"blog">;
  next?: CollectionEntry<'blog'>;
  prev?: CollectionEntry<'blog'>;
  related?: CollectionEntry<'blog'>;
};

const { post, next, prev, related } = Astro.props;
---

{
  next || prev || related ? (
    <div class="mx-auto max-w-3xl py-8 px-4 my-6 mb-0 rounded-md bg-slate-100 border-slate-200">
      <div class="mx-auto max-w-xl">
        {
          next || prev ? (
            <p class="text-base font-bold mb-4 text-center"><strong>{post.data.title}</strong> is part of a post series.</p>
            <div class="flex justify-between mb-8">
              <div class="flex-shrink-0">{prev ? (
                <a class="text-blue-700 flex flex-col gap-2 w-full font-bold" href={`/blog/${prev.slug}`}>
                  <img src={prev.data.cover.src} alt={prev.data.coverAlt ?? ''} class="w-24 h-14 mx-auto object-cover" />
                  <span class="text-left text-sm">&lsaquo; Prev Post</span>
                </a>
              ) : undefined}</div>
              <div class="flex-shrink-0">{next ? (
                <a class="text-blue-700 flex flex-col gap-2 w-full font-bold" href={`/blog/${next.slug}`}>
                  <img src={next.data.cover.src} alt={next.data.coverAlt ?? ''} class="w-24 h-16 mx-auto object-cover" />
                  <span class="text-right text-sm">Next Post &rsaquo;</span>
                </a>
              ) : undefined}</div>
            </div>
          ) : undefined
        }
        { (next || prev) && related ? (
          <hr />
        ) : undefined}
        {
          related ? (
            <div class="mx-auto mt-8 flex flex-col items-center">
              <p>Related post:<br /><strong>{related.data.title}</strong></p>
              <a class="font-bold text-blue-700 text-xl text-center my-4 mx-auto inline-block" href={`/blog/${related.slug}`}>
                <img src={related.data.cover.src} alt={related.data.coverAlt ?? ''} class="w-40 h-28 mx-auto object-cover" />
              </a>
            </div>
          ) : undefined
        }
      </div>
    </div>
  ) : undefined
}
